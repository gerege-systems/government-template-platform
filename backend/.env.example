# Backend config mounted into the api + migrate containers at /app/.env.
# Copy to `backend.env` (gitignored) and fill in real secrets for deployment.
# DB host/redis host use the compose service names (db, redis).

PORT=8080
ENVIRONMENT=development        # internal docker DB has no TLS; dev mode skips the verify-full guard
DEBUG=false
ALLOWED_ORIGINS=https://temp.dgov.mn

DB_POSTGRE_DRIVER=postgres
DB_POSTGRE_DSN=host=db port=5432 user=gerege password=CHANGE_ME_DB dbname=gerege_template sslmode=disable
DB_POSTGRE_URL=postgres://db:5432/gerege_template?sslmode=verify-full
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFE_MINS=15

JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_PLUS_CHAR_SECRET
JWT_EXPIRED=5
JWT_REFRESH_EXPIRED=7
JWT_ISSUER=temp.dgov.mn

OTP_MAX_ATTEMPTS=5

BCRYPT_COST=12

OTEL_EXPORTER=
OTEL_SAMPLE_RATIO=1.0

REDIS_HOST=redis:6379
REDIS_PASS=CHANGE_ME_REDIS
REDIS_EXPIRED=5

# Trusted reverse-proxy IP/CIDRs (comma-separated). Empty = do NOT trust
# X-Forwarded-For (use peer RemoteAddr) — fail-safe against rate-limit/audit spoofing.
# IMPORTANT: behind the reference topology (nginx -> web BFF -> api) the api only
# ever sees the web/nginx peer IP, so per-IP rate limiting + audit attribution
# collapse to ONE bucket unless this is set. Point it at the docker network + any
# proxy hop, e.g. TRUSTED_PROXIES=172.16.0.0/12,127.0.0.1 (the BFF forwards the
# real client IP as X-Forwarded-For). The api logs a boot warning if left empty.
TRUSTED_PROXIES=

# GeregeCloud Verify API — бүх email/SMS OTP (бүртгэл баталгаажуулах + нууц үг
# сэргээх) энэ үйлчилгээгээр явна; SMTP огт ашиглахгүй. Production-д
# VERIFY_API_KEY заавал (хоосон бол boot амжилтгүй).
VERIFY_API_BASE=https://verify.gecloud.mn/v1
VERIFY_API_KEY=CHANGE_ME_GECLOUD_VERIFY_KEY
VERIFY_CHANNEL=email

# OBSERVABILITY_TOKEN — production-д /metrics ба /swagger/doc.json-г хамгаалах
# bearer token. Хоосон бол эдгээр endpoint production-д 404 (бүрэн хаалттай).
# Хандахдаа: Authorization: Bearer <token>. development-д хамаагүй (нээлттэй).
OBSERVABILITY_TOKEN=

# Google OAuth (Sign in with Google) — server-side authorization-code flow.
# Хоосон бол Google login идэвхгүй (feature fail-closed). CLIENT_SECRET нь НУУЦ,
# зөвхөн api контейнерт үлдэнэ (browser-т хэзээ ч гарахгүй); CLIENT_ID нь нууц
# биш (web контейнерт BFF consent URL-д ашиглагдана). Google Cloud Console →
# Credentials-ээс авна.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# dgov SSO (sso.dgov.mn, OIDC) — eID-ийн зэрэгцээ 2 дахь нэвтрэлт (Landing дээр
# "dgov SSO-ээр нэвтрэх" товч). ISSUER, CLIENT_ID, CLIENT_SECRET, REDIRECT_URI
# ДӨРӨВ бүгд бөглөгдсөн үед л идэвхжинэ; аль нэг нь хоосон бол урсгал inert
# (товч харагдахгүй). CLIENT_ID/SECRET-ийг sso.dgov.mn дээр Hydra OAuth2 client
# (confidential, client_secret_basic) болгож бүртгүүлж авна. REDIRECT_URI нь тэр
# client-д бүртгэсэн callback-тай ЯГ таарах ёстой бөгөөд frontend-ийн
# /sso/callback зам руу заана (host = ALLOWED_ORIGINS-ийн host). SECRET нь НУУЦ,
# зөвхөн api контейнерт үлдэнэ. ISSUER хоосон бол https://sso.dgov.mn default.
SSO_ISSUER=https://sso.dgov.mn
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=https://temp.dgov.mn/sso/callback
SSO_SCOPE=openid profile email
# Mobile (iOS/Android) PKCE public client_id — native урсгалд (/v1/sso/native)
# ашиглана. sso.dgov.mn дээр public client (token_endpoint_auth_method=none)
# болгож, native redirect (жишээ geregetemp://oauth2/callback)-тай бүртгэнэ.
SSO_NATIVE_CLIENT_ID=template-gerege-mn-ios

# Gerege Space — апп-ын өөрийн SFTP хадгалалт (Холболтууд хэсэгт "Gerege Space").
# Хэрэглэгч бүрт QUOTA_BYTES хэмжээний зай (default 2MB) олгож, файлыг
# BASE_PATH/users/<userID>/ дор хадгална. PASSWORD нь НУУЦ — зөвхөн api
# контейнерт үлдэнэ. Хоосон бол feature идэвхгүй (endpoint 500, UI зохицуулна).
GSPACE_HOST=
GSPACE_PORT=22
GSPACE_USER=
GSPACE_PASSWORD=CHANGE_ME_GSPACE_PASSWORD
GSPACE_BASE_PATH=gerege-space
GSPACE_QUOTA_BYTES=2097152
